generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Utilisateurs & rôles ─────────────────────────────────────────────────────

/// Rôles applicatifs :
/// - ADMIN  : accès total (paramètres, suppression agent, gestion utilisateurs)
/// - USER   : accès fonctionnel (import, consultation, simulation)
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String
  password            String // bcrypt hash
  role                String   @default("USER") // "ADMIN" | "USER"
  isActive            Boolean  @default(true)
  /// Statut de validation du compte : "PENDING" | "APPROVED" | "REJECTED"
  /// Les comptes créés directement par l'admin sont APPROVED par défaut.
  /// Les demandes via le formulaire public d'inscription démarrent en PENDING.
  registrationStatus  String   @default("APPROVED")
  registrationComment String? // Motif fourni lors de l'inscription
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  auditLogs    AuditLog[]
  agentFilters UserAgentFilter[]
}

/// Journal d'audit — trace les actions sensibles (suppression, modification RH, etc.)
///
/// Redondance volontaire userId / userEmail :
/// - userId       : relation vers User, utile pour joindre (filtrer par compte actif).
///                 Devient NULL si le compte est supprimé (onDelete: SetNull) afin de
///                 préserver la ligne d'audit — un journal ne doit jamais être purgé
///                 par cascade.
/// - userEmail    : snapshot immuable au moment de l'action. Garantit la traçabilité
///                 même après suppression du compte ou changement d'email.
/// Ne jamais supprimer l'un des deux champs sans revoir la politique d'audit.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String // ex : "DELETE_AGENT", "UPDATE_WORK_RULES", "LOGIN"
  entity    String // ex : "Agent", "WorkRule", "User"
  entityId  String?
  details   String   @default("{}") // JSON
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Affichage personnalisé ────────────────────────────────────────────────

/// Filtre d'agents par utilisateur — jusqu'à 4 slots par utilisateur (0..3).
/// Un seul slot peut avoir isActive = true à la fois (contrainte métier gérée
/// côté API). isActive = false sur tous les slots → affichage normal.
/// Les agents sélectionnés sont stockés dans UserAgentFilterItem (relation items)
/// pour garantir l'intégrité référentielle et la cascade automatique
/// (agent supprimé → item retiré automatiquement, plus aucun ID zombie).
model UserAgentFilter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slotIndex Int      @default(0)
  name      String   @default("Filtre 1")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items UserAgentFilterItem[]

  @@unique([userId, slotIndex])
  @@index([userId])
}

/// Items d'un filtre d'agents utilisateur.
/// Une ligne = un agent sélectionné dans le filtre d'un utilisateur.
/// Cascade sur UserAgentFilter (filtre supprimé → items supprimés)
/// et sur Agent (agent supprimé → item automatiquement retiré du filtre).
model UserAgentFilterItem {
  id        String   @id @default(cuid())
  filterId  String
  agentId   String
  createdAt DateTime @default(now())

  filter UserAgentFilter @relation(fields: [filterId], references: [id], onDelete: Cascade)
  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([filterId, agentId])
  @@index([filterId])
  @@index([agentId])
}

// ─── Agents ──────────────────────────────────────────────────────────────────

/// Règle de gestion : un agent importé est RÉMANENT.
/// Il ne peut être supprimé QUE par un administrateur via une action explicite.
/// Un import ultérieur ne supprime jamais un agent absent du fichier.
/// La suppression est LOGIQUE (deletedAt non null) pour préserver l'historique.
model Agent {
  id               String    @id @default(cuid())
  matricule        String    @unique
  nom              String
  prenom           String
  uch              String?
  codeUch          String?
  codeApes         String?
  codeSymboleGrade String?
  codeCollegeGrade Int?
  posteAffectation String?
  agentReserve     Boolean   @default(false)
  peutFaireNuit    Boolean   @default(true)
  peutEtreDeplace  Boolean   @default(false)
  regimeB          Boolean   @default(false)
  regimeC          Boolean   @default(false)
  habilitations    String    @default("[]")
  /// LPA de base (Lieu de Prise d'Attachement) — détermine le hors-LPA
  lpaBaseId        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Suppression logique — null = agent actif, non-null = supprimé par un admin
  deletedAt        DateTime?
  deletedByEmail   String? // email de l'admin ayant supprimé

  lpaBase                 Lpa?                     @relation(fields: [lpaBaseId], references: [id])
  planningLignes          PlanningLigne[]
  agentJsDeplacementRules AgentJsDeplacementRule[]
  userFilterItems         UserAgentFilterItem[]

  @@index([deletedAt])
}

// ─── Planning ─────────────────────────────────────────────────────────────────

model PlanningImport {
  id         String   @id @default(cuid())
  filename   String
  importedAt DateTime @default(now())
  nbLignes   Int
  nbAgents   Int
  erreurs    String   @default("[]")
  isActive   Boolean  @default(true)

  lignes PlanningLigne[]
}

model PlanningLigne {
  id               String  @id @default(cuid())
  importId         String
  agentId          String?
  uch              String?
  codeUch          String?
  nom              String
  prenom           String
  matricule        String
  codeApes         String?
  codeSymboleGrade String?
  codeCollegeGrade Int?

  dateDebutPop        DateTime
  heureDebutPop       String
  heureFinPop         String
  dateFinPop          DateTime
  amplitudeCentesimal Int?
  amplitudeHHMM       String?
  dureeEffectiveCent  Int?
  dureeEffectiveHHMM  String?

  jsNpo           String
  codeJs          String?
  typeJs          String?
  valeurNpo       Int?
  uchJs           String?
  codeUchJs       String?
  codeRoulementJs String?
  numeroJs        String?

  jourPlanning DateTime

  import PlanningImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  agent  Agent?         @relation(fields: [agentId], references: [id])

  @@unique([matricule, jourPlanning])
  @@index([agentId])
  @@index([importId])
  @@index([matricule])
  @@index([dateDebutPop])
  @@index([dateFinPop])
  @@index([jourPlanning])
}

// ─── Règles métier ────────────────────────────────────────────────────────────

model WorkRule {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Float
  category  String
  updatedAt DateTime @updatedAt
}

// ─── Énumérations ─────────────────────────────────────────────────────────────

/// Degré de priorité d'un type de JS dans la simulation.
/// OBLIGATOIRE  : la JS doit être couverte ; pénalité maximale si non couverte.
/// DERNIER_RECOURS : la JS peut rester non couverte ; pénalité réduite,
///                  et l'agent planifié sur cette JS peut être "figé" pour
///                  en libérer un autre (si autoriserFigeage est activé).
enum FlexibiliteJs {
  OBLIGATOIRE
  DERNIER_RECOURS
}

// ─── Référentiel JsType ───────────────────────────────────────────────────────

/// Type de journée de service (référentiel central).
/// code peut être un préfixe (ex: "GIV") ou un typeJs exact (ex: "FIX").
/// Définit les horaires standard et la nature nuit/jour.
model JsType {
  id                 String        @id @default(cuid())
  code               String        @unique
  libelle            String
  heureDebutStandard String // "HH:MM"
  heureFinStandard   String // "HH:MM"
  dureeStandard      Int // minutes
  estNuit            Boolean       @default(false)
  regime             String? // optionnel : ex "B", "C"
  actif              Boolean       @default(true)
  /// Priorité de couverture en simulation. Configuré dans l'écran Types JS.
  flexibilite        FlexibiliteJs @default(OBLIGATOIRE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  lpaJsTypes            LpaJsType[]
  agentDeplacementRules AgentJsDeplacementRule[]
}

// ─── LPA — Lieu de Prise d'Attachement ────────────────────────────────────────

/// Lieu de prise d'attachement d'un agent.
/// Détermine quelles JS sont considérées "dans la LPA" via la table LpaJsType.
model Lpa {
  id        String   @id @default(cuid())
  code      String   @unique
  libelle   String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents     Agent[]
  lpaJsTypes LpaJsType[]
}

/// Table de correspondance LPA ↔ JsType.
/// Si un JsType est référencé pour une LPA → JS considérée "dans la LPA".
/// Sinon → JS hors LPA → déclenchement possible du déplacement.
model LpaJsType {
  id       String @id @default(cuid())
  lpaId    String
  jsTypeId String

  lpa    Lpa    @relation(fields: [lpaId], references: [id], onDelete: Cascade)
  jsType JsType @relation(fields: [jsTypeId], references: [id], onDelete: Cascade)

  @@unique([lpaId, jsTypeId])
  @@index([lpaId])
}

// ─── Codes NPO exclus des simulations ────────────────────────────────────────

/// Codes NPO (non-présence) qui excluent un agent des simulations d'imprévus.
/// Chaque code est un préfixe : "MA" exclut "MA01", "MAL", etc.
/// Configurables par l'administrateur. Pré-peuplés au premier lancement.
model NpoExclusionCode {
  id        String   @id @default(cuid())
  code      String   @unique // préfixe, ex : "MA", "AT", "CLM"
  libelle   String // ex : "Maladie ordinaire"
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Préfixes de codes JS additionnels assimilés à des JS Z (sans charge réelle).
/// S'ajoutent aux règles built-in (suffixe " Z", préfixe "FO", typeJs="DIS").
/// Un agent sur un code matchant un de ces préfixes est mobilisable sans cascade
/// (réaffectation directe, +15 pts au scoring, exclusion des propositions
/// d'habilitation post-import). Configurables par l'administrateur.
model ZeroLoadPrefix {
  id        String   @id @default(cuid())
  prefixe   String   @unique // préfixe, ex : "DISP", "FORM", "PSE"
  libelle   String // ex : "Disponibilité programmée"
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Règles de déplacement agent ──────────────────────────────────────────────

/// Règles spécifiques de déplacement par agent.
/// Permet de définir les temps de trajet et d'éventuels overrides horsLpa.
/// Match par jsTypeId (prioritaire) OU prefixeJs (fallback, préfixe le plus long).
model AgentJsDeplacementRule {
  id                       String   @id @default(cuid())
  agentId                  String
  jsTypeId                 String? // match exact via JsType
  prefixeJs                String? // match par préfixe sur codeJs (fallback)
  horsLpa                  Boolean? // override : force JS hors/dans LPA
  tempsTrajetAllerMinutes  Int      @default(0)
  tempsTrajetRetourMinutes Int      @default(0)
  actif                    Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  agent  Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  jsType JsType? @relation(fields: [jsTypeId], references: [id])

  @@index([agentId])
}
